APP_NAME=SightAhead API
ENVIRONMENT=local
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI (орчуулга — үндсэн)
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
TRANSLATION_PROVIDER=openai

# Azure TTS
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia
TTS_PROVIDER=azure

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_CREDENTIALS_JSON=

# Gemini (орчуулга fallback)
GEMINI_API_KEY=

# Транскрипт (RapidAPI 'video-transcript-scraper') — YouTube IP-block тойрно
RAPID_API_URL=https://video-transcript-scraper.p.rapidapi.com/transcript/youtube
RAPIDAPI_KEY=

# GPU voice-over (Modal F5 app — gpu/f5_modal.py deploy хий)
MODAL_F5_APP=sightahead-f5
MODAL_F5_CLASS=F5
# Backend-ээс Modal-д нэвтрэх: `modal token new` (~/.modal.toml) эсвэл эдгээр:
MODAL_TOKEN_ID=ak-PEIUWo1kVEpviWReYXyyyO
MODAL_TOKEN_SECRET=as-pNQ5NCWdvnnmD0rywpK9pZ

# Cost guardrails — GPU зарцуулахаас өмнө хэт урт оролтыг таслана
MAX_DUB_SEGMENTS=1500
MAX_TRANSCRIPT_CHARS=60000

# Firebase deploy дээр (Railway/Render) — file биш JSON/base64 ашигла
FIREBASE_CREDENTIALS_JSON_BASE64=

# Логийн түвшин (DEBUG = per-segment лог)
LOG_LEVEL=INFO

# Локал тест
ENABLE_LOCAL_PROCESSING=true
